{
  "system": "outbound-acquisition",
  "status": "initializing",
  "objective": "Generate conversations with qualified business leads",
  "human_notify_condition": "lead replies",
  "active_agents": [
    "leads",
    "research",
    "outreach",
    "follow-up-cron",
    "analyst",
    "reply-monitor"
  ],
  "memory_structure": {
    "raw": "/leads/raw/",
    "processed": "/leads/processed/",
    "contacted": "/leads/contacted/",
    "replied": "/leads/replied/",
    "outreach": "/outreach/",
    "reports": "/reports/"
  },
  "target_niches": [
    "home services",
    "moving companies",
    "local service businesses",
    "churches"
  ],
  "lead_fields": [
    "business_name",
    "website",
    "email",
    "phone",
    "city"
  ],
  "filter_rules": [
    "remove directories",
    "remove duplicates",
    "remove no-contact-info"
  ],
  "outreach_sequence": {
    "initial": {
      "day": 0,
      "channel": "email",
      "fallback": "sms"
    },
    "followup_1": {
      "day": 2,
      "message": "Just wanted to follow up on this — worth a quick look if you're not capturing leads instantly."
    },
    "followup_2": {
      "day": 5,
      "message": "This is something that can run 24/7 for you — happy to show you if you're open."
    },
    "followup_3": {
      "day": 10,
      "message": "Should I close this out or do you want to take a look?"
    }
  },
  "reply_handling": {
    "monitor_channels": ["email", "sms", "whatsapp", "telegram"],
    "on_reply": [
      "save to /leads/replied/",
      "analyze intent",
      "notify David via Telegram"
    ],
    "notification_format": {
      "message": "NEW REPLY:\nBusiness: {name}\nMessage: {their_reply}\nContact: {email/phone}\nSuggested response: {suggestion}"
    }
  },
  "daily_metrics": [
    "leads_scraped",
    "leads_contacted",
    "replies",
    "positive_responses"
  ],
  "created": "2026-03-28T21:05:00-04:00"
}
